# ─────────────────────────────────────────────────────────────────────────────
# ODI — example environment file
#
# Copy to `.env` and adjust. The Go binary loads this file automatically via
# godotenv (see internal/cli/root.go). docker-compose also reads it for the
# OpenSearch / PostgreSQL containers.
#
# Credentials that accept a `keychain:<name>` prefix are looked up via the
# host OS keychain (e.g. `B2_KEY=keychain:b2-key`). Useful to avoid storing
# secrets in plaintext on shared hosts.
# ─────────────────────────────────────────────────────────────────────────────

# ── Infrastructure (docker-compose) ──────────────────────────────────────────

# OpenSearch admin password (required by docker-compose)
OPENSEARCH_ADMIN_PASSWORD=change_me_strong_password

# PostgreSQL password (required by docker-compose)
POSTGRES_PASSWORD=change_me_postgres_password

# ── OpenSearch (consumed by the Go server / indexer) ─────────────────────────

# OpenSearch endpoint
OPENSEARCH_ADDR=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change_me_strong_password
# Skip TLS verification (only for local self-signed dev clusters)
OPENSEARCH_SKIP_TLS=true
# Index name (default: documents)
OPENSEARCH_INDEX=documents

# ── Storage backend ──────────────────────────────────────────────────────────

# One of: b2, filesystem
STORAGE_TYPE=filesystem

# Backblaze B2 (required when STORAGE_TYPE=b2). B2 blobs are AES-256-GCM
# encrypted with a key derived from B2_PASSPHRASE via PBKDF2 (pkg/crypt).
B2_ACCOUNT=
B2_KEY=
B2_BUCKET_NAME=
B2_PASSPHRASE=

# Filesystem storage root (required when STORAGE_TYPE=filesystem).
# NOTE: filesystem storage is plaintext — put it on a FUSE-encrypted mount
# if you need encryption at rest.
FS_PATH=./data/blobs

# ── OCR ──────────────────────────────────────────────────────────────────────

# Reachable ocr-server instance (https://github.com/denysvitali/ocr-server)
OCR_API_ADDR=https://ocr.lan:8443
# Optional: path to a CA bundle for the OCR server's TLS cert
OCR_API_CA_PATH=

# ── Zefix (Swiss commercial register) ────────────────────────────────────────

# PostgreSQL DSN for company-name enrichment. Leave empty to disable.
ZEFIX_DSN=postgres://postgres:change_me_postgres_password@localhost:5455/postgres?sslmode=disable

# ── Scanner (live ingest) ────────────────────────────────────────────────────

# AirScan / eSCL hostname or IP
SCANNER_NAME=

# ── Server / HTTP ────────────────────────────────────────────────────────────

# Comma-separated list of CORS origins for /api/v1/*
# (default: http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional bearer-token authentication for /api/v1/* routes.
# If unset, the API runs unauthenticated (development only).
API_TOKEN=

# Optional TLS — set both to serve HTTPS directly. Leave empty to serve plain
# HTTP and terminate TLS at a reverse proxy.
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Logging ──────────────────────────────────────────────────────────────────

# One of: debug, info, warn, error (default: info)
LOG_LEVEL=info
